{
    "version": "0.2.0",
    "configurations": [
        {
            // using gdb to debug TestApplication
            "name": "Debug TestApplication",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/bin/TestApplication",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "build"
        },
        {
            // using gdb to debug toolgplat
            "name": "Debug toolgplat",
            "type": "cppdbg",
